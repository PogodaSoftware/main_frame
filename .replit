modules = ["nodejs-20", "python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "frontend"

[[workflows.workflow]]
name = "frontend"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd Frontend/portfolioResume && npm start -- --port 5000 --host 0.0.0.0"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 37145
externalPort = 3001

[[ports]]
localPort = 39305
externalPort = 3000

[deployment]
workingDirectory = "Frontend/portfolioResume"
deploymentTarget = "autoscale"
run = ["bash", "-c", "npx --yes serve dist/portfolio-resume-frontend/browser -l 5000"]
build = ["bash", "-c", "npm install && npm run build"]
